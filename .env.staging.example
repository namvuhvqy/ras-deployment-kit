# Copy to .env.staging on VPS and fill secrets there.
RAS_API_PORT=8080
RAS_DB_PATH=/data/ras-store.json
ZERNIO_MODE=dry-run
ZERNIO_BASE_URL=https://zernio.com/api/v1
ZERNIO_API_KEY=
ZERNIO_TIMEOUT_MS=30000
RAS_WORKER_BATCH_SIZE=20
RAS_WORKER_IDLE_MS=5000
RAS_WORKER_MAX_RETRIES=5
RAS_WORKER_BASE_RETRY_MS=60000
