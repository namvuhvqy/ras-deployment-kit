{
  "name": "ras-deployment-kit",
  "version": "0.1.0",
  "private": true,
  "description": "RunAgentSys RAS deployment kit: API, worker, queue, and Zernio adapter skeleton.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
