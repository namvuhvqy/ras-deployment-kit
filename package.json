    "schema:sql": "tsx scripts/print-schema.ts"
  },
  "dependencies": {
    "@types/node": "^20.17.19",
    "typescript": "^5.7.3"
  },
  "devDependencies": {
    "tsx": "^4.19.2"
  }
}
